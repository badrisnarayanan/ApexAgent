<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Records an unhandled exception or fatal error that occurred during agent message processing. Linked to the message log in which the error occurred.</description>
    <label>Agent Error Log</label>
    <pluralLabel>Agent Error Logs</pluralLabel>
    <nameField>
        <label>Name</label>
        <type>AutoNumber</type>
        <displayFormat>ERROR-{000000}</displayFormat>
        <startingNumber>1</startingNumber>
    </nameField>
    <deploymentStatus>Deployed</deploymentStatus>
    <sharingModel>ControlledByParent</sharingModel>
    <compactLayoutAssignment>Error_Log_Compact</compactLayoutAssignment>
    <actionOverrides>
        <actionName>View</actionName>
        <content>ApexAgent_Error_Log_Record_Page</content>
        <formFactor>Large</formFactor>
        <skipRecordTypeSelect>false</skipRecordTypeSelect>
        <type>Flexipage</type>
    </actionOverrides>
    <actionOverrides>
        <actionName>View</actionName>
        <content>ApexAgent_Error_Log_Record_Page</content>
        <formFactor>Small</formFactor>
        <skipRecordTypeSelect>false</skipRecordTypeSelect>
        <type>Flexipage</type>
    </actionOverrides>
</CustomObject>
